---
import '../styles/global.css';
import DotPattern from '../components/react/DotPattern';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Renan Nunes Pacheco — Currículo Profissional',
  description = 'Currículo profissional de Renan Nunes Pacheco. Suporte técnico, vendas, atendimento, freelancer autônomo, personal trainer, produtividade, IA generativa e melhoria de processos.',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000000" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800;900&family=Geist+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="bg-bg text-text antialiased">
    <DotPattern client:load />

    <div class="relative" style="z-index: 2;">
      <slot />
    </div>
  </body>
</html>
