---
interface Props {
  command: string;
  index: string;
  total: string;
  centered?: boolean;
}

const { command, index, total, centered = false } = Astro.props;
const label = `${index}/${total}`;
---

<div
  class:list={[
    'flex items-center gap-3 mb-6 font-mono text-sm',
    centered && 'justify-center',
  ]}
>
  <span class="text-accent">{'>'}</span>
  <span class="text-text-muted uppercase tracking-widest">{command}</span>
  {centered && <span class="text-accent">{'>'}</span>}
  <div class:list={['h-px bg-border', centered ? 'w-12' : 'flex-1']}></div>
  <span class="text-text-subtle">{label}</span>
</div>
<slot />
