---
interface Props {
  title: string;
  subtitle: string;
  badge: string;
  label?: string;
}

const { title, subtitle, badge, label } = Astro.props;
---

<div class="card card-hover">
  <div class="flex flex-wrap items-start justify-between gap-2 mb-3 font-mono">
    <div>
      <h4 class="font-bold text-text text-sm">{title}</h4>
      <div class="text-accent text-xs mt-1">@ {subtitle}</div>
    </div>
    <span class="badge">{badge}</span>
  </div>
  {label && (
    <div class="text-label mb-3">
      // {label}
    </div>
  )}
  <slot />
</div>
