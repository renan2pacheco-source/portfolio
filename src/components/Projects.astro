---
import AnimatedSection from './react/AnimatedSection';
import SectionHeader from './SectionHeader.astro';
import ProjectCard from './react/ProjectCard';
import { projects } from '../data/content';
---

<section id="projetos" class="section">
  <div class="container-narrow">
    <AnimatedSection client:visible>
      <SectionHeader command="ls projects/" index="04" total="05">
        <h2 class="section-title text-balance">
          Coisas que <span class="text-accent">construí</span>.
        </h2>
        <p class="section-subtitle mb-12 text-pretty">
          Projetos, laboratórios e ferramentas que demonstram meu jeito de resolver problemas.
        </p>
      </SectionHeader>
    </AnimatedSection>

    <div class="grid sm:grid-cols-2 gap-4">
      {projects.map((project, i) => (
        <ProjectCard
          client:visible
          name={project.name}
          description={project.description}
          tags={project.tags}
          link={project.link}
          index={i}
        />
      ))}
    </div>

    <AnimatedSection client:visible delay={0.4}>
      <div class="mt-10 text-center font-mono">
        <a
          href="https://instagram.com/nucleo_digit4l"
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted text-sm hover:text-accent transition-colors"
        >
          <span class="text-accent">$</span> ver mais no instagram →
        </a>
      </div>
    </AnimatedSection>
  </div>
</section>
