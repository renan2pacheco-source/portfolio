---
import AnimatedSection from './react/AnimatedSection';
import SectionHeader from './SectionHeader.astro';
import ProjectCard from './react/ProjectCard';
import { results } from '../data/content';
---

<section id="resultados" class="section">
  <div class="container-narrow">
    <AnimatedSection client:visible>
      <SectionHeader command="cat resultado-empresa.txt" index="03" total="05">
        <h2 class="section-title text-balance">
          Como posso gerar <span class="text-accent">resultado</span>.
        </h2>
        <p class="section-subtitle mb-12 text-pretty">
          O foco não é mostrar projeto pessoal: é mostrar onde minhas habilidades reduzem atrito, melhoram atendimento e organizam a rotina da empresa.
        </p>
      </SectionHeader>
    </AnimatedSection>

    <div class="grid sm:grid-cols-2 gap-4">
      {results.map((project, i) => (
        <ProjectCard
          client:visible
          name={project.name}
          description={project.description}
          tags={project.tags}
          link={project.link}
          index={i}
        />
      ))}
    </div>
  </div>
</section>
